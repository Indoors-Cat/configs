##i3/System Submap:
set $sys (b) bar, (p) picom, (r) recompile, (t) task-mgr, (v) volume, (x) logout, (space) float
bindsym $mod+i mode "$sys"
        mode "$sys" {
             bindsym b bar mode toggle
             bindsym Shift+b exec --no-startup-id i3-msg border toggle
             bindsym p exec --no-startup-id ~/.config/i3/scripts/picom-toggle.sh
             bindsym r exec i3 reload && i3 restart
             bindsym t exec --no-startup-id htop;focus
             bindsym v exec --no-startup-id pavucontrol;focus
             bindsym x exec --no-startup-id i3-msg exit
             bindsym space floating toggle

#             bindsym e mode "default"
             bindsym Escape mode "default"
        }

##Resize Mode:
set $resize (b,n,m) border, (h,j,k,l) resize
bindsym $mod+r mode "$resize"
        mode "$resize" {
             bindsym b  border 1pixel
             bindsym n  border normal
             bindsym m  border none
             bindsym h  resize shrink width 2 px or 2 ppt
             bindsym j  resize grow height 2 px or 2 ppt
             bindsym k  resize shrink height 2 px or 2 ppt
             bindsym l  resize grow width 2 px or 2 ppt

             bindsym Escape mode "default"
        }

##i3 Gaps:
for_window [class="^.*"] border pixel 2
gaps inner 5
gaps outer 5

set $mode_gaps Gaps: (o) outer, (i) inner
set $mode_gaps_outer Outer Gaps: +|-|0 (local), Shift + +|-|0 (global)
set $mode_gaps_inner Inner Gaps: +|-|0 (local), Shift + +|-|0 (global)
bindsym $mod+g mode "$mode_gaps"
        mode "$mode_gaps" {
             bindsym o mode "$mode_gaps_outer"
             bindsym i mode "$mode_gaps_inner"

             bindsym Escape mode "default"
        }

        mode "$mode_gaps_outer" {
             bindsym plus        gaps outer current plus 5
             bindsym minus       gaps outer current minus 5
             bindsym 0           gaps outer current set 0
             bindsym Shift+plus  gaps outer all plus 5
             bindsym Shift+minus gaps outer all minus 5
             bindsym Shift+0     gaps outer all set 0

             bindsym Escape mode "default"
        }

        mode "$mode_gaps_inner" {
             bindsym plus        gaps inner current plus 5
             bindsym minus       gaps inner current minus 5
             bindsym 0           gaps inner current set 0
             bindsym Shift+plus  gaps inner all plus 5
             bindsym Shift+minus gaps inner all minus 5
             bindsym Shift+0     gaps inner all set 0

             bindsym Escape mode "default"
        }

